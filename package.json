{
  "name": "digital-human-factory",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc && vite build",
    "start": "node server/index.js",
    "setup": "node scripts/setup.mjs",
    "install:all": "node scripts/setup.mjs",
    "install:system": "node scripts/install-models.mjs --system-only",
    "install:models": "node scripts/install-models.mjs",
    "package:offline:mac": "node scripts/package-offline-mac.mjs",
    "package:offline:win": "node scripts/package-offline-win.mjs",
    "doctor:gpu": "node scripts/windows-gpu-doctor.mjs",
    "asr": "node scripts/asr-tool.mjs",
    "llm": "node scripts/llm-tool.mjs",
    "tts": "node scripts/tts-tool.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "test:p0": "node scripts/e2e-p0-browser.mjs",
    "test:source-extract": "node scripts/e2e-source-extract.mjs",
    "test:ui": "node scripts/ui-layout-audit.mjs",
    "test:video": "node scripts/e2e-generate-video.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "ali-oss": "^6.23.0",
    "concurrently": "^9.2.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
