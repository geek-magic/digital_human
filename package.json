{
  "name": "digital-human-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production node server/index.js",
    "asr": "node scripts/asr-tool.mjs",
    "llm": "node scripts/llm-tool.mjs",
    "tts": "node scripts/tts-tool.mjs",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "test:p0": "node scripts/e2e-p0-browser.mjs",
    "test:source-extract": "node scripts/e2e-source-extract.mjs",
    "test:ui": "node scripts/ui-layout-audit.mjs",
    "test:video": "node scripts/e2e-generate-video.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
